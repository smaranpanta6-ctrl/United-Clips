const {
Client,
GatewayIntentBits,
SlashCommandBuilder,
REST,
Routes,
EmbedBuilder,
ActionRowBuilder,
ButtonBuilder,
ButtonStyle,
ChannelType,
PermissionFlagsBits
} = require("discord.js");

const client = new Client({
    intents:[
        GatewayIntentBits.Guilds,
        GatewayIntentBits.GuildMembers
    ]
});


const TOKEN = "YOUR_BOT_TOKEN";
const GUILD_ID = "YOUR_SERVER_ID";


// COMMAND SETUP

const commands = [

new SlashCommandBuilder()
.setName("campaign")
.setDescription("Campaign system")

.addSubcommand(sub =>
sub
.setName("create")
.setDescription("Create a campaign")

.addStringOption(option =>
option
.setName("name")
.setDescription("Campaign name")
.setRequired(true)
)

.addStringOption(option =>
option
.setName("client")
.setDescription("Client name")
.setRequired(true)
)

.addStringOption(option =>
option
.setName("budget")
.setDescription("Payment budget")
.setRequired(true)
)

.addStringOption(option =>
option
.setName("deadline")
.setDescription("Deadline")
.setRequired(true)
)

)

].map(command=>command.toJSON());



const rest = new REST({
version:"10"
}).setToken(TOKEN);



(async()=>{

await rest.put(
Routes.applicationGuildCommands(
"YOUR_CLIENT_ID",
GUILD_ID
),
{
body:commands
}
);

console.log("Commands loaded");

})();




// BOT READY

client.once("ready",()=>{

console.log(
`${client.user.tag} is online`
);

});





// COMMANDS

client.on(
"interactionCreate",
async interaction=>{


if(interaction.isChatInputCommand()){


if(
interaction.commandName==="campaign"
){


if(
interaction.options.getSubcommand()
==="create"
){


let name =
interaction.options.getString("name");


let company =
interaction.options.getString("client");


let budget =
interaction.options.getString("budget");


let deadline =
interaction.options.getString("deadline");



// CREATE CHANNEL


let channel =
await interaction.guild.channels.create({

name:
name
.toLowerCase()
.replaceAll(" ","-"),

type:
ChannelType.GuildText,


});




// EMBED


let embed =
new EmbedBuilder()

.setColor("Blue")

.setTitle(
"🎬 "+name
)

.setDescription(
`
**Client**
${company}

**Budget**
$${budget}

**Deadline**
${deadline}


**Status**
🟢 OPEN


Need editors.
Apply below.
`
)

.setFooter({
text:
"United Clips Campaign System"
});



// BUTTONS


let buttons =
new ActionRowBuilder()

.addComponents(

new ButtonBuilder()

.setCustomId("apply")

.setLabel("🎬 Apply")

.setStyle(
ButtonStyle.Success
),


new ButtonBuilder()

.setCustomId("submit")

.setLabel("📤 Submit Edit")

.setStyle(
ButtonStyle.Primary
),


new ButtonBuilder()

.setCustomId("approve")

.setLabel("✅ Approve")

.setStyle(
ButtonStyle.Success
),


new ButtonBuilder()

.setCustomId("reject")

.setLabel("❌ Reject")

.setStyle(
ButtonStyle.Danger
)


);



await channel.send({

embeds:[
embed
],

components:[
buttons
]

});



await interaction.reply({

content:
`✅ Campaign created: ${channel}`,

ephemeral:true

});


}


}


}





// BUTTON SYSTEM


if(interaction.isButton()){


if(
interaction.customId==="apply"
){

return interaction.reply({

content:
"✅ You applied for this campaign!",

ephemeral:true

});

}



if(
interaction.customId==="submit"
){

return interaction.reply({

content:
"📤 Send your edit link to staff.",

ephemeral:true

});

}




if(
interaction.customId==="approve"
){

return interaction.reply(
"✅ Edit approved"
);

}




if(
interaction.customId==="reject"
){

return interaction.reply(
"❌ Edit rejected"
);

}



}



});





client.login(TOKEN);
